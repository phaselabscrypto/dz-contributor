# DZ Contributor Rewards — environment configuration.
#
# Copy to .env.local for local dev. In production, set via:
#   vercel env add <NAME> production
#
# Every variable is optional. Each unset variable degrades a feature
# gracefully — see the comment for what falls back when it's missing.

# ────────────────────────────────────────────────────────────────────
# Shapley solver service (Rust)
# ────────────────────────────────────────────────────────────────────

# HTTPS endpoint of the deployed network-shapley-rs HTTP wrapper.
# When unset: site falls back to the TS coalition-enumeration solver
# (directionally correct, not bit-comparable to Foundation output).
# Build with services/shapley-rs/Dockerfile — see services/shapley-rs/README.md
# SHAPLEY_SERVICE_URL=https://your-shapley-service.example.com

# ────────────────────────────────────────────────────────────────────
# On-chain reads (pending DZ Foundation IDL)
# ────────────────────────────────────────────────────────────────────

# When unset OR ONCHAIN_ENABLED != "1": all /api/onchain/* routes return
# 503 with a stable shape. Frontend treats them as soft-disabled.

# Solana RPC endpoint. Public default works but rate-limited.
# Recommended: Helius / Triton dedicated tier.
# Helius format: https://mainnet.helius-rpc.com/?api-key=<YOUR_HELIUS_KEY>
# Set the production key via `vercel env add SOLANA_RPC_URL production`.
# Do NOT commit the key to the repo — only the template URL here.
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# DZ ledger RPC (REQUIRED for any /api/onchain/* route + the decode
# scripts). Contributor-rewards records live on the DZ ledger
# (a Solana sidechain), NOT on Solana mainnet.
#
# There is no default in code: the previous default embedded a paid
# rpcpool API key in source, which leaked into the deployed JS bundle.
# Set this in Vercel (production) and `.env.local` (dev) explicitly.
#
# The public rpcpool endpoint below is published in the
# doublezero-offchain README and works without an API key for typical
# development volumes. For production, use your own rate-limited tier.
# DZ_LEDGER_RPC_URL=https://doublezero-mainnet-beta.rpcpool.com/<YOUR_RPCPOOL_KEY>

# Master DZ registry program (owns Metro/Device/Link/Contributor accounts).
# Pending DZ Q6 — flip ONCHAIN_ENABLED=1 once this lands.
# DZ_REGISTRY_PROGRAM_ID=

# DZ rewards distribution program (revenue-distribution, on Solana mainnet).
# Already known: dzrevZC94tBLwuHw1dyynZxaXTWyp7yocsinyEVPtt4
# DZ_REWARDS_PROGRAM_ID=dzrevZC94tBLwuHw1dyynZxaXTWyp7yocsinyEVPtt4

# DZ record program (holds contributor-rewards / reward-input / telemetry
# records on the DZ ledger). Already known and hardcoded as the default
# in lib/onchain/dz-rewards-record.ts:
#   dzrecxigtaZQ3gPmt2X5mDkYigaruFR1rHCqztFTvx7
# Override here only if a fork or test deployment is needed.
# DZ_RECORD_PROGRAM_ID=dzrecxigtaZQ3gPmt2X5mDkYigaruFR1rHCqztFTvx7

# Rewards accountant pubkey — the on-chain authority that writes
# contributor-rewards records. Also the base for create_with_seed when
# deriving each epoch's record address. Already known from probing
# mainnet records:
#   acCSLNUiAECGPGayZgBHHDuZW4hLkM7L6hxphXbogBR
# Resolvable dynamically from ProgramConfig.rewards_accountant_key under
# DZ_REWARDS_PROGRAM_ID, but the constant works for now.
# DZ_REWARDS_ACCOUNTANT=acCSLNUiAECGPGayZgBHHDuZW4hLkM7L6hxphXbogBR

# Seed prefix used by the scheduler to derive each epoch's
# contributor-rewards record address. Full seed list:
#   [prefix, epoch_u64_le, b"shapley_output"]
# Confirmed by DZ Foundation 2026-05-14: prefix = "dz_contributor_rewards"
# (example.config.toml's "rewards" was a typo). Already hardcoded as
# the default in lib/onchain/dz-rewards-record.ts — override here
# only if the scheduler config changes.
# DZ_CONTRIBUTOR_REWARDS_PREFIX=dz_contributor_rewards

# Master switch. "1" turns on /api/onchain/* routes. Anything else (or
# unset) keeps them returning 503.
# ONCHAIN_ENABLED=0

# ────────────────────────────────────────────────────────────────────
# Canonical Shapley inputs (pending DZ Foundation Q1)
# ────────────────────────────────────────────────────────────────────

# Base URL where the Foundation publishes per-epoch CSVs:
#   {base}/private_links.csv
#   {base}/devices.csv
#   {base}/public_links.csv
#   {base}/demand.csv
# The literal "{N}" in the URL is replaced with the epoch number per request.
# When set: /api/shapley uses canonical inputs and labels responses
# `inputSource: "canonical-foundation"` so the validation harness can
# report bit-comparable drift instead of estimate-vs-aggregate.
# When unset: falls back to S3 snapshot-derived inputs.
# DZ_CANONICAL_INPUTS_URL=https://github.com/doublezerofoundation/shapley-inputs/raw/main/epoch-{N}

# ────────────────────────────────────────────────────────────────────
# Observability (no-op until vendor is wired)
# ────────────────────────────────────────────────────────────────────

# Sentry DSN. When unset: errors log to console in dev, swallow in prod.
# Wire @sentry/nextjs and uncomment the SDK calls in lib/observability.ts
# to activate. Web vitals always post to /api/vitals (which is also
# a no-op sink until you swap it for a real backend).
# NEXT_PUBLIC_SENTRY_DSN=

# Anchor account discriminator handling for borsh decoders. When the
# canonical IDL ships, accounts may or may not have the standard 8-byte
# Anchor discriminator. Default: assumes yes (strip 8 bytes before decode).
# Set to "0" if the canonical accounts are raw borsh structs.
# DZ_ACCOUNT_HAS_DISCRIMINATOR=1

# ────────────────────────────────────────────────────────────────────
# Site URL (for OG images + canonical URLs)
# ────────────────────────────────────────────────────────────────────

# Used by app/layout.tsx metadataBase and app/opengraph-image.tsx.
# Falls back to https://dz-contributor.vercel.app if unset.
# NEXT_PUBLIC_SITE_URL=https://rewards.phase.cc
